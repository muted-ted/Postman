    {
      "name": "Cart item list",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "const items = response.cart.items;",
              "const totals = response.totals.items;",
              "",
              "items.forEach(item => {",
              "    const totalInfo = totals.find(t => t.item_id === item.item_id);",
              "    console.log(`",
              "        Name: ${item.name}",
              "        SKU: ${item.sku}",
              "        Item ID: ${item.item_id}",
              "        Qty: ${item.qty}",
              "        Price (incl. tax): ${totalInfo.price_incl_tax} EUR",
              "    `);",
              "});",
              "",
              "console.log(`Grand Total: ${response.totals.grand_total} EUR`);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\"input\":{\"country_id\":\"LT\",\"post_code\":null}}",
